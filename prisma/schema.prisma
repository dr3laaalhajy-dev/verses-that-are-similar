// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           Int     @id @default(autoincrement())
  username     String  @unique
  password     String
  isSuperAdmin Boolean @default(false)
}

model AdminCode {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  role      String   @default("ADMIN") // "ADMIN" or "SUPERADMIN"
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Challenge {
  id          Int      @id @default(autoincrement())
  keyword     String   @unique
  verses      Json     // Array of verse objects
  category    String   @default("")
  level       String   @default("")
  type        String   @default("STANDARD") // "STANDARD", "AUDIO", "COMPLETION", "SURAH"
  audioUrl    String?  // For AUDIO type
  options     Json?    // For COMPLETION type
  correctText String?  // For SURAH type or other single correct answers
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Player {
  id                    Int      @id @default(autoincrement())
  deviceId              String   @unique
  name                  String
  points                Int      @default(0)
  cups                  Int      @default(0)
  completedChallengeIds Json     @default("[]")
  seerahCompleted       Boolean  @default(false)
  generalCompleted      Boolean  @default(false)
  quranCompleted        Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  // 1v1 Relations
  rooms1                Room[]   @relation("Player1Rooms")
  rooms2                Room[]   @relation("Player2Rooms")
  wonRooms              Room[]   @relation("WinnerRooms")
}

model Room {
  id              String   @id @default(uuid())
  code            String   @unique
  player1Id       Int
  player2Id       Int?
  player1Progress Int      @default(0)
  player2Progress Int      @default(0)
  status          String   @default("WAITING") // WAITING, PLAYING, FINISHED
  winnerId        Int?
  challengeIds    Json     // Array of challenge IDs
  surahFilters    Json     @default("[]") // Renamed to keep backward compatibility or used for category
  categoryFilter  String   @default("")   // New explicit field for category
  questionCount   Int      @default(5)    // Number of questions in the challenge
  maxPlayers      Int      @default(2)    // Phase 1: Multiplayer Group Rooms
  gameMode        String   @default("STANDARD") // STANDARD, COMPLETION, SURAH
  timePerQuestion Int      @default(20)   // Time in seconds
  playersProgress Json     @default("{}") // Store progress as { playerId: progress }
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  player1         Player   @relation("Player1Rooms", fields: [player1Id], references: [id])
  player2         Player?  @relation("Player2Rooms", fields: [player2Id], references: [id])
  winner          Player?  @relation("WinnerRooms", fields: [winnerId], references: [id])
}
